# Definition for singly-linked list.
class ListNode:
    def __init__(self, val=0, next=None):
        self.val = val
        self.next = next

class Solution:
    def getDecimalValue(self, head: ListNode) -> int:
        num = 0
        current = head
        
        while current:
            num = (num << 1) | current.val   # shift left and add current bit
            current = current.next
            
        return num
