from collections import defaultdict

class Solution:
    def countPairs(self, n, edges, queries):
        deg = [0] * (n + 1)
        shared = defaultdict(int)

        # Count degrees and shared edges
        for u, v in edges:
            deg[u] += 1
            deg[v] += 1
            if u > v:
                u, v = v, u
            shared[(u, v)] += 1

        sorted_deg = sorted(deg[1:])
        res = []

        for q in queries:
            count = 0
            left, right = 0, n - 1

            # Two pointer to count pairs
            while left < right:
                if sorted_deg[left] + sorted_deg[right] > q:
                    count += right - left
                    right -= 1
                else:
                    left += 1

            # Remove invalid pairs caused by shared edges
            for (u, v), c in shared.items():
                if deg[u] + deg[v] > q and deg[u] + deg[v] - c <= q:
                    count -= 1

            res.append(count)

        return res
