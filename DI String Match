class Solution:
    def diStringMatch(self, s: str) -> list[int]:
        low, high = 0, len(s)
        result = []  
        for ch in s:
            if ch == 'I':
                result.append(low)
                low += 1
            else:  # 'D'
                result.append(high)
                high -= 1  
        result.append(low)  # low == high   
        return result
